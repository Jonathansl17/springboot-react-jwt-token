{
  "info": {
    "_postman_id": "tc16-30-pedidos-dereck",
    "name": "TC16-30 Pedidos - Dereck",
    "description": "Casos de prueba TC-16 al TC-28. Nota: GET/PUT/DELETE /api/orders requiere ADMIN. El USER ve sus ordenes via GET /api/users/me.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    { "key": "base_url", "value": "http://localhost:8080" },
    { "key": "user_token", "value": "" },
    { "key": "user2_token", "value": "" },
    { "key": "admin_token", "value": "" },
    { "key": "order_id", "value": "" },
    { "key": "user2_order_id", "value": "" },
    { "key": "expired_token", "value": "PEGAR_TOKEN_EXPIRADO_AQUI" }
  ],
  "item": [
    {
      "name": "SETUP",
      "item": [
        {
          "name": "SETUP - Login user (user/user)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SETUP: Login de usuario principal exitoso\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set(\"user_token\", json.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user\",\n  \"password\": \"user\"\n}" },
            "url": { "raw": "{{base_url}}/auth/authenticate", "host": ["{{base_url}}"], "path": ["auth", "authenticate"] }
          },
          "response": []
        },
        {
          "name": "SETUP - Login admin (admin/admin)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SETUP: Login de administrador exitoso\", function () {",
                  "    pm.response.to.have.status(200);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set(\"admin_token\", json.accessToken);"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"admin\",\n  \"password\": \"admin\"\n}" },
            "url": { "raw": "{{base_url}}/auth/authenticate", "host": ["{{base_url}}"], "path": ["auth", "authenticate"] }
          },
          "response": []
        },
        {
          "name": "SETUP - Registrar user2 (si no existe)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SETUP: user2 disponible para pruebas cruzadas\", function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400, 409]);",
                  "});",
                  "if (pm.response.code === 201) {",
                  "    var json = pm.response.json();",
                  "    pm.collectionVariables.set(\"user2_token\", json.accessToken);",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": { "mode": "raw", "raw": "{\n  \"username\": \"user1\",\n  \"password\": \"user1\",\n  \"name\": \"User Uno\",\n  \"email\": \"user1@test.com\"\n}" },
            "url": { "raw": "{{base_url}}/auth/signup", "host": ["{{base_url}}"], "path": ["auth", "signup"] }
