              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SETUP: Orden de user creada para pruebas de edicion/eliminacion\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set(\"order_id\", json.id);"
