            "url": { "raw": "{{base_url}}/api/orders", "host": ["{{base_url}}"], "path": ["api", "orders"] }
          },
          "response": []
        },
        {
          "name": "SETUP - Crear orden de user2 (para TC-26)",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "pm.test(\"SETUP: Orden de user2 creada para prueba TC-26\", function () {",
                  "    pm.response.to.have.status(201);",
                  "});",
                  "var json = pm.response.json();",
                  "pm.collectionVariables.set(\"user2_order_id\", json.id);"
