        {
          "name": "Intentar registro con inyeccion SQL",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Validar que la base de datos se mantenga íntegra y responda de forma segura\r",
                  "pm.test(\"Seguridad: El sistema neutraliza y procesa de forma segura el payload SQL\", function () {\r",
                  "    // Si el backend lo guarda como texto literal de forma segura, devolverá 201 Created.\r",
                  "    // Si tiene un filtro de caracteres especiales en los inputs, devolverá 400 Bad Request.\r",
                  "    // Ambos comportamientos son seguros frente a una inyección SQL.\r",
                  "    pm.expect(pm.response.code).to.be.oneOf([201, 400]);\r",
                  "});\r",
                  "\r",
                  "// 2. Validar que el servidor no exponga errores internos del motor de la base de datos\r",
                  "pm.test(\"Integridad de la Base de Datos: No se filtran excepciones de SQL o Hibernate\", function () {\r",
                  "    var respuestaTexto = pm.response.text();\r",
                  "    \r",
                  "    // Auditamos que no se expongan palabras clave de errores de bases de datos que ayuden a un atacante\r",
                  "    pm.expect(respuestaTexto).to.not.include(\"SQLException\");\r",
                  "    pm.expect(respuestaTexto).to.not.include(\"SQL syntax\");\r",
                  "    pm.expect(respuestaTexto).to.not.include(\"HibernateException\");\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
          ],
