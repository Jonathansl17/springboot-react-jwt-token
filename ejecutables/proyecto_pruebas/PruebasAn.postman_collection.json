                      "\r",
                      "// 2. Validar que la respuesta contenga el mensaje de error solicitado en la especificación\r",
                      "pm.test(\"Validación de Interfaz: El sistema retorna un mensaje explícito de error\", function () {\r",
                      "    var jsonData = pm.response.json();\r",
                      "    \r",
                      "    // Verificamos que exista un campo de mensaje (puede llamarse 'message' o 'error')\r",
                      "    var errorFields = jsonData.message || jsonData.error || JSON.stringify(jsonData);\r",
                      "    pm.expect(errorFields).to.be.a('string').and.not.empty;\r",
                      "});"
