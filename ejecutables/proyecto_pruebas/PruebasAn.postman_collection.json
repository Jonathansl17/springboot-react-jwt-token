        {
          "name": "Acceder a ruta protegida sin token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "// 1. Validar que el mecanismo de autenticación bloquee el acceso anónimo\r",
                  "pm.test(\"Seguridad de Endpoints: Acceso denegado a /api/orders sin token - Código 401\", function () {\r",
                  "    pm.response.to.have.status(401);\r",
                  "});\r",
                  "\r",
                  "// 2. Validar que el servidor responda de forma segura ante una petición no autorizada\r",
                  "pm.test(\"Control de Accesos: El sistema deniega la carga de datos sin credenciales\", function () {\r",
                  "    var respuestaTexto = pm.response.text();\r",
                  "    \r",
                  "    // Al no enviar token, validamos que la respuesta sea un cuerpo vacío o un mensaje de rechazo genérico\r",
                  "    if (respuestaTexto) {\r",
                  "        // Si el servidor envía un JSON de error, verificamos que no contenga datos de órdenes reales\r",
                  "        pm.expect(respuestaTexto).to.not.include(\"orderId\");\r",
                  "        pm.expect(respuestaTexto).to.not.include(\"totalPrice\");\r",
                  "    } else {\r",
                  "        // El comportamiento por defecto seguro de Spring es devolver un cuerpo vacío en el 401\r",
                  "        pm.expect(respuestaTexto).to.be.string;\r",
                  "    }\r",
                  "});"
                ],
                "type": "text/javascript",
                "packages": {},
                "requests": {}
              }
            }
