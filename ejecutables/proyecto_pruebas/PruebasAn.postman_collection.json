                      "});\r",
                      "\r",
                      "// 2. Validar que la respuesta contenga los detalles o mensajes de error correspondientes\r",
                      "pm.test(\"Validación de Interfaz: El sistema detalla los campos faltantes de autenticación\", function () {\r",
                      "    var respuestaTexto = pm.response.text();\r",
                      "    \r",
                      "    // Si el backend responde con la estructura JSON de errores (como en el SignUp)\r",
                      "    try {\r",
                      "        var jsonData = JSON.parse(respuestaTexto);\r",
                      "        pm.expect(jsonData.errors).to.be.an('array').and.not.empty;\r",
                      "    } catch(e) {\r",
                      "        // Si responde en formato de texto plano o string simple, verificamos que no venga vacío\r",
