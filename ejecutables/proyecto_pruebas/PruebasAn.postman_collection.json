        {
          "name": "SignUp",
          "item": [
            {
              "name": "Registro con datos validos",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// Validar que el servidor creó el usuario exitosamente\r",
                      "pm.test(\"Estatus 201: Registro exitoso en la base de datos\", function () {\r",
                      "    pm.response.to.have.status(201);\r",
                      "});\r",
                      "\r",
                      "// Validar que entrega el token necesario para iniciar sesión automáticamente\r",
                      "pm.test(\"Retorna el accessToken para dar paso a la página principal\", function () {\r",
                      "    var jsonData = pm.response.json();\r",
                      "    pm.expect(jsonData).to.have.property('accessToken');\r",
                      "    pm.expect(jsonData.accessToken).to.be.a('string').and.not.empty;\r",
                      "    \r",
                      "    // Guardamos el token en las variables globales de Postman\r",
                      "    pm.globals.set(\"auth_token\", jsonData.accessToken);\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"username\": \"AngieTec\",\r\n  \"password\": \"Angie123\",\r\n  \"name\": \"AngieQA\",\r\n  \"email\": \"angie@tec.com\"\r\n}",
                  "options": {
                    "raw": {
                      "language": "json"
                    }
                  }
                },
                "url": {
                  "raw": "{{base_url}}/auth/signup",
                  "host": [
                    "{{base_url}}"
                  ],
                  "path": [
                    "auth",
                    "signup"
                  ]
                }
              },
              "response": []
            },
            {
              "name": "Registro con campos vacíos",
              "event": [
                {
                  "listen": "test",
                  "script": {
                    "exec": [
                      "// 1. Validar que el servidor bloquee la petición por datos inválidos (400 Bad Request)\r",
                      "pm.test(\"Estatus 400: Registro rechazado por campos obligatorios vacíos\", function () {\r",
                      "    pm.response.to.have.status(400);\r",
                      "});\r",
                      "\r",
                      "// 2. Validar que la respuesta contenga los mensajes de error detallados de la validación\r",
                      "pm.test(\"Validación de Interfaz: El sistema indica que hay campos faltantes\", function () {\r",
                      "    var jsonData = pm.response.json();\r",
                      "    \r",
                      "    // Verificamos que se dispare la excepción de validación de Spring\r",
                      "    pm.expect(jsonData.exception).to.include(\"MethodArgumentNotValidException\");\r",
                      "    \r",
                      "    // Validamos que exista la lista de errores y que no venga vacía\r",
                      "    pm.expect(jsonData.errors).to.be.an('array').and.not.empty;\r",
                      "    \r",
                      "    // Comprobamos que al menos uno de los mensajes por defecto indique que no debe estar vacío\r",
                      "    var tieneMensajeVacio = jsonData.errors.some(function(err) {\r",
                      "        return err.defaultMessage && err.defaultMessage.includes(\"vacío\");\r",
                      "    });\r",
                      "    pm.expect(tieneMensajeVacio).to.be.true;\r",
                      "});"
                    ],
                    "type": "text/javascript",
                    "packages": {},
                    "requests": {}
                  }
                }
              ],
              "request": {
                "method": "POST",
                "header": [],
                "body": {
                  "mode": "raw",
                  "raw": "{\r\n  \"username\": \"\",\r\n  \"password\": \"\",\r\n  \"name\": \"\",\r\n  \"email\": \"\"\r\n}",
