    {
      "name": "TC57 - Datos sensibles no expuestos en errores",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{adminToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/users/no_existe_xyz", "host": ["{{baseUrl}}"], "path": ["api", "users", "no_existe_xyz"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const body = pm.response.text().toLowerCase();",
              "pm.test('No expone stacktrace', () => pm.expect(body).to.not.include('exception'));",
              "pm.test('No expone SQL', () => pm.expect(body).to.not.include('select '));",
              "pm.test('No expone password', () => pm.expect(body).to.not.include('password'));",
              "pm.test('No expone clase Java', () => pm.expect(body).to.not.include('com.ivanfranchin'));"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },

    {
      "name": "TC58 - No registrar admin desde API publica",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"fakeadmin_{{$timestamp}}\",\n  \"password\": \"pass1234\",\n  \"name\": \"Fake Admin\",\n  \"email\": \"fakeadmin_{{$timestamp}}@test.com\",\n  \"role\": \"ADMIN\"\n}"
        }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Signup ok 201', () => pm.response.to.have.status(201));",
              "const token = pm.response.json().accessToken;",
              "const payload = JSON.parse(atob(token.split('.')[1].replace(/-/g,'+').replace(/_/g,'/')));",
              "pm.test('Rol asignado NO es ADMIN', () => {",
              "  const roles = JSON.stringify(payload).toUpperCase();",
              "  pm.expect(roles).to.include('USER');",
              "  pm.expect(roles).to.not.include('\"ADMIN\"');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    }
