    {
      "name": "SETUP - Crear segundo usuario (para TC53)",
      "request": {
        "method": "POST",
        "header": [{ "key": "Content-Type", "value": "application/json" }],
        "url": { "raw": "{{baseUrl}}/auth/signup", "host": ["{{baseUrl}}"], "path": ["auth", "signup"] },
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"user_other_{{$timestamp}}\",\n  \"password\": \"password123\",\n  \"name\": \"OtherUser\",\n  \"email\": \"other_{{$timestamp}}@test.com\"\n}"
        }
      },
      "event": [
        {
          "listen": "prerequest",
          "script": {
            "exec": [
              "const ts = Date.now();",
              "pm.collectionVariables.set('secondUserEmail', `other_${ts}@test.com`);",
              "pm.collectionVariables.set('secondUserName', `user_other_${ts}`);"
            ],
            "type": "text/javascript"
          }
        },
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('Segundo usuario creado 201', () => pm.response.to.have.status(201));",
              "const json = pm.response.json();",
              "pm.collectionVariables.set('secondUserToken', json.accessToken);"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },

    {
      "name": "TC46 - Redireccion a login sin sesion (manual UI)",
      "request": {
        "method": "GET",
        "url": { "raw": "{{frontendUrl}}/userpage", "host": ["{{frontendUrl}}"], "path": ["userpage"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('NOTA: este caso se valida manualmente en el navegador', () => pm.expect(true).to.be.true);",
              "// Postman no ejecuta JS del SPA. Abrir {{frontendUrl}}/userpage sin login y verificar redireccion a /login"
            ],
            "type": "text/javascript"
          }
        }
      ]
