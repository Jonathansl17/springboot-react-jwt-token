    {
      "name": "TC47a - Usuario regular ve solo sus pedidos (GET /me)",
      "request": {
        "method": "GET",
        "header": [{ "key": "Authorization", "value": "Bearer {{userToken}}" }],
        "url": { "raw": "{{baseUrl}}/api/users/me", "host": ["{{baseUrl}}"], "path": ["api", "users", "me"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test('200 OK', () => pm.response.to.have.status(200));",
              "const j = pm.response.json();",
              "pm.test('Solo orders del propio usuario', () => {",
              "  if (!j.orders) return;",
              "  pm.expect(Array.isArray(j.orders)).to.be.true;",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
    },
    {
      "name": "TC47b - Usuario regular NO accede a /api/orders (403)",
      "request": {
