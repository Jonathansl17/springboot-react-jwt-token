              "const j = pm.response.json();",
              "pm.test('Estructura UserDto', () => {",
              "  ['id','username','name','email','role','orders'].forEach(k => pm.expect(j).to.have.property(k));",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ]
