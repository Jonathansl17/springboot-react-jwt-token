    {
      "name": "TC55 - Headers de seguridad HTTP",
      "request": {
        "method": "GET",
        "url": { "raw": "{{baseUrl}}/public/numberOfUsers", "host": ["{{baseUrl}}"], "path": ["public", "numberOfUsers"] }
      },
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "const expected = ['X-Content-Type-Options','X-Frame-Options','Cache-Control'];",
              "expected.forEach(h => {",
              "  pm.test(`Header ${h} presente`, () => pm.expect(pm.response.headers.get(h)).to.not.be.null);",
